{
  "name": "local-media-library",
  "version": "1.0.3",
  "description": "\u672c\u5730\u5f71\u89c6\u5e93\u7ba1\u7406\u7cfb\u7edf",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:frontend\"",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:frontend": "cd frontend && npm run dev",
    "prebuild": "npm run rebuild:sqlite3 || echo \"\u8b66\u544a: sqlite3 \u91cd\u65b0\u7f16\u8bd1\u5931\u8d25\uff0c\u5c06\u4f7f\u7528\u73b0\u6709\u7248\u672c\u6216\u7531 electron-builder \u81ea\u52a8\u5904\u7406\"",
    "build": "npm run build:frontend && npm run build:electron",
    "build:quick": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend && npm run build",
    "build:frontend:test": "cd frontend && npm run build -- --mode test",
    "build:electron": "electron-builder",
    "build:electron:test": "electron-builder --config electron-builder.test.yml",
    "build:test": "npm run build:frontend:test && npm run build:electron:test",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:sqlite3": "electron-rebuild -f -w sqlite3",
    "start": "electron ."
  },
  "keywords": [
    "electron",
    "javlibrary",
    "media-library"
  ],
  "author": "Achaiccccc",
  "license": "GPL-3.0",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "iconv-lite": "^0.6.3",
    "js2xmlparser": "^5.0.0",
    "jschardet": "^3.0.0",
    "opencc-js": "^1.0.5",
    "sequelize": "^6.35.2",
    "sharp": "^0.33.2",
    "sqlite3": "^6.0.1",
    "xml2js": "^0.6.2"
  }
}